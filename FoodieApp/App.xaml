<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FoodieApp.Converters"
             x:Class="FoodieApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- All value converters registered globally so every page can reference them -->
            <converters:FavouriteIconConverter     x:Key="FavouriteIconConverter" />
            <converters:InverseBoolConverter       x:Key="InverseBoolConverter" />
            <converters:CountToBoolConverter       x:Key="CountToBoolConverter" />
            <converters:TtsButtonTextConverter     x:Key="TtsButtonTextConverter" />
            <converters:FavFilterTextConverter     x:Key="FavFilterTextConverter" />
            <converters:MealTypeIconConverter      x:Key="MealTypeIconConverter" />
            <converters:NullToBoolConverter        x:Key="NullToBoolConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
