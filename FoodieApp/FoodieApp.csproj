<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0-android</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>FoodieApp</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationTitle>FoodieApp</ApplicationTitle>
    <ApplicationId>com.foodieapp.mobile</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
    <AndroidLinkMode>None</AndroidLinkMode>
  </PropertyGroup>

  <ItemGroup>
    <!-- App icon generated from pure-shape SVG (no text elements) -->
    <MauiIcon Include="Resources\AppIcon\appicon.svg"
              ForegroundFile="Resources\AppIcon\appiconfg.svg"
              Color="#FF6B35" />
    <MauiSplashScreen Include="Resources\Splash\splash.svg"
                      Color="#FF6B35"
                      BaseSize="128,128" />
    <MauiFont Include="Resources\Fonts\*" />
    <MauiAsset Include="Resources\Raw\**"
               LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <!-- Explicit PNG mipmap fallbacks so the icon always renders correctly on Android -->
    <AndroidResource Include="Platforms\Android\Resources\mipmap-mdpi\appicon.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-mdpi\appicon_round.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-hdpi\appicon.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-hdpi\appicon_round.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xhdpi\appicon.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xhdpi\appicon_round.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xxhdpi\appicon.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xxhdpi\appicon_round.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xxxhdpi\appicon.png" />
    <AndroidResource Include="Platforms\Android\Resources\mipmap-xxxhdpi\appicon_round.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls"               Version="$(MauiVersion)" />
    <PackageReference Include="Microsoft.Maui.Controls.Compatibility" Version="$(MauiVersion)" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug"    Version="8.0.0" />
    <PackageReference Include="CommunityToolkit.Mvvm"                 Version="8.2.2" />
    <PackageReference Include="CommunityToolkit.Maui"                 Version="7.0.1" />
    <PackageReference Include="Newtonsoft.Json"                       Version="13.0.3" />
    <!-- ZXing.Net core library for barcode decoding logic -->
    <PackageReference Include="ZXing.Net"                             Version="0.16.9" />
  </ItemGroup>

</Project>
