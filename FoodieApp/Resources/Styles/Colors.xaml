<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#FF6B35</Color>
    <Color x:Key="PrimaryDark">#E55A24</Color>
    <Color x:Key="PrimaryLight">#FFB299</Color>
    <Color x:Key="Secondary">#2EC4B6</Color>
    <Color x:Key="Accent">#FFBF69</Color>

    <Color x:Key="PageBackground">#F7F3EF</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="DividerColor">#E0D8D0</Color>

    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#666666</Color>
    <Color x:Key="TextHint">#AAAAAA</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="ErrorColor">#F44336</Color>

    <!-- Dark mode variants -->
    <Color x:Key="DarkBackground">#121212</Color>
    <Color x:Key="DarkCard">#2C2C2C</Color>
    <Color x:Key="DarkTextPrimary">#F5F5F5</Color>
    <Color x:Key="DarkTextSecondary">#AAAAAA</Color>

</ResourceDictionary>
