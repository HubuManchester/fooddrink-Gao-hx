<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodieApp.ViewModels"
             x:Class="FoodieApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- Appearance -->
            <Label Text="Appearance" Style="{StaticResource SubheadingStyle}" Margin="0,8,0,10" />
            <Frame Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Dark Mode" Style="{StaticResource BodyStyle}" FontAttributes="Bold" />
                            <Label Text="Switch between light and dark theme"
                                   Style="{StaticResource CaptionStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"
                                OnColor="{StaticResource Primary}"
                                SemanticProperties.Hint="Toggle dark mode" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Font Size" Style="{StaticResource BodyStyle}" FontAttributes="Bold" />

                        <!--
                            On Android the Picker renders its selected text using the platform
                            EditText widget. When no TextColor is set explicitly the widget
                            inherits the window's default text colour, which on some Android
                            versions is white — invisible against the white card background in
                            light mode. Binding TextColor via AppThemeBinding ensures the text
                            is always readable regardless of the active theme.
                        -->
                        <Picker ItemsSource="{Binding FontSizeLabels}"
                                SelectedIndex="{Binding FontSizeIndex}"
                                FontSize="{DynamicResource GlobalBodyFontSize}">
                            <Picker.TextColor>
                                <AppThemeBinding Light="{StaticResource TextPrimary}"
                                                 Dark="{StaticResource DarkTextPrimary}" />
                            </Picker.TextColor>
                        </Picker>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Accessibility -->
            <Label Text="Accessibility" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,10" />
            <Frame Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Text to Speech" Style="{StaticResource BodyStyle}" FontAttributes="Bold" />
                            <Label Text="Read recipe steps aloud while cooking"
                                   Style="{StaticResource CaptionStyle}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsTtsEnabled}"
                                OnColor="{StaticResource Primary}"
                                SemanticProperties.Hint="Toggle text to speech" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- About -->
            <Label Text="About" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,10" />
            <Frame Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Version" Style="{StaticResource BodyStyle}" />
                        <Label Grid.Column="1" Text="1.0.0" Style="{StaticResource CaptionStyle}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" />
                    <Button Text="Help and FAQ"
                            Command="{Binding OpenHelpCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Frame>

            <!-- Reset -->
            <Button Text="Reset All Settings"
                    Command="{Binding ResetCommand}"
                    BackgroundColor="{StaticResource ErrorColor}"
                    TextColor="White" CornerRadius="12"
                    FontSize="{DynamicResource GlobalBodyFontSize}" FontAttributes="Bold"
                    Padding="20,14" HeightRequest="50"
                    HorizontalOptions="Fill"
                    Margin="0,0,0,32" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
